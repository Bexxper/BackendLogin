<!DOCTYPE html>
<html lang="en" style="background-color: #121212; width: 100%; height: 100%;">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Secret PS Login</title>
    <link rel="icon" type="image/png"
        href="https://s3.eu-west-1.amazonaws.com/cdn.growtopiagame.com/website/resources/assets/images/growtopia.ico"
        sizes="16x16" />

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500&family=Roboto:wght@400;500&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Roboto', sans-serif;
            background: #121212;
            color: #fff;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .login-container {
            background: #1e1e1e;
            padding: 40px 30px;
            border-radius: 12px;
            box-shadow: 0 0 20px rgba(255, 165, 0, 0.3);
            width: 100%;
            max-width: 400px;
            text-align: center;
        }

        .login-title {
            font-family: 'Orbitron', sans-serif;
            font-size: 28px;
            color: orange;
            margin-bottom: 25px;
        }

        .form-control {
            width: 100%;
            padding: 12px 15px;
            margin-bottom: 20px;
            border-radius: 8px;
            border: none;
            font-size: 16px;
            background: #2a2a2a;
            color: #fff;
        }

        .form-control::placeholder {
            color: #bbb;
        }

        .btn-login {
            width: 100%;
            padding: 12px;
            background: orange;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: bold;
            color: #121212;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-login:hover {
            background: #ff9c00;
        }

        .btn-register {
            width: 100%;
            padding: 12px;
            background: #2a2a2a;
            border: 2px solid orange;
            border-radius: 8px;
            font-size: 14px;
            font-weight: bold;
            color: orange;
            cursor: pointer;
            margin-top: 10px;
            transition: 0.3s;
        }

        .btn-register:hover {
            background: orange;
            color: #121212;
        }

        .footer-text {
            margin-top: 15px;
            font-size: 12px;
            color: #888;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-title">Secret PS</div>

        <!-- Login Form -->
        <form method="POST" action="/player/growid/login/validate" autocomplete="off">
            <input type="text" name="growId" class="form-control" placeholder="Your Growtopia Name *" required />
            <input type="password" name="password" class="form-control" placeholder="Your Password *" required />
            <input type="submit" class="btn-login" value="Login" />
        </form>

        <!-- Register Form -->
        <form method="POST" action="/player/growid/login/validate">
            <input type="hidden" name="growId" value="" />
            <input type="hidden" name="password" value="" />
            <input type="submit" class="btn-register" value="Don't have a Growtopia ID? Register here!" />
        </form>

        <div class="footer-text">
            &copy; 2026 Secret PS. All rights reserved.
        </div>
    </div>
</body>
</html>
